modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "NODE_ENV=production node --enable-source-maps ./artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm --filter @workspace/erp-system run build && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/db run push-force"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ERP Mobile Dev"

[[workflows.workflow]]
name = "ERP Mobile Dev"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/erp-mobile && HEALTH_PORT=8099 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN node scripts/dev-start.js"
waitForPort = 8099

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["gh", "pm2"]

[userenv]

[userenv.shared]
JWT_SECRET = "halal-tech-erp-f8561b273ce0b52c89552ca3ae69e90deebe340b88e4992d344eff46fdd9806a"
JWT_REFRESH_SECRET = "decbf20d7d6ee54a2b174e02ad25e0ff626b3fef804185b3a50f273dae78051e722647600a306c9289b3c44be3780359"
TOTP_ENCRYPTION_KEY = "2e28db5ebb91553c7e5f7866410cabde"
