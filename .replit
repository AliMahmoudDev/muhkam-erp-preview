modules = ["nodejs-20", "web", "bash", "postgresql-16"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [[artifacts]]
  id = "artifacts/erp-mobile"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"
  run = ["bash", "-c", "NODE_ENV=production node --enable-source-maps ./artifacts/api-server/dist/index.mjs"]
  build = ["bash", "-c", "pnpm --filter @workspace/erp-system run build && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/db run push-force"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]

  [agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
  integrations = ["github:1.0.0"]

  [postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

  [nix]
channel = "stable-25_05"
packages = ["gh", "pm2"]

  [userenv]

  [userenv.shared]
  NODE_ENV = "development"
  ALLOWED_ORIGINS = ""
JWT_SECRET = "38b267cbc60e50b82622195454ff681210303c73b5571c67ccb13421af7e50ecde6c75ba4e7745d14456f1b340c440f7"
DEFAULT_ADMIN_PIN = "202020"
