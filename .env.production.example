# =============================================================================
# MUHKAM ERP — Production Environment Template
# =============================================================================
# Copy this file to `.env` on the production VPS and fill in real values.
#
#   cp .env.production.example .env
#   nano .env
#
# RULES:
#   - NEVER commit the real `.env` to git (it is gitignored).
#   - NEVER share real secret values in chat, screenshots, or reports.
#   - Generate every secret on the server with the commands shown below.
# =============================================================================


# ── REQUIRED — server refuses to start without these ─────────────────────────
# (validated in artifacts/api-server/src/index.ts → REQUIRED_ENV_VARS)

# PostgreSQL connection string for the production database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Primary JWT signing key (access tokens). Minimum 32 chars; 64 recommended.
# Generate: openssl rand -hex 32
JWT_SECRET=

# Refresh-token signing key. MUST be different from JWT_SECRET. 64 recommended.
# Generate: openssl rand -hex 32
JWT_REFRESH_SECRET=

# AES key used to encrypt TOTP (2FA) secrets at rest.
# NOTE: deploy.yml auto-generates this on first deploy if missing.
# Generate: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# AES key used to encrypt server-side backup files.
# NOTE: deploy.yml auto-generates this on first deploy if missing.
# ⚠️  CRITICAL: Once the first encrypted backup is created, this key MUST NEVER
#     change. If it is lost or rotated, ALL existing encrypted backups become
#     permanently undecryptable. Back this value up in a secure password manager.
# Generate: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=


# ── REQUIRED FOR SECURE FEATURES — fail-closed if empty ──────────────────────

# Comma-separated IP allowlist for super-admin routes.
# Empty in production = super-admin access is BLOCKED (fail-closed, by design).
# Set to the static IP(s) you will administer from.
# Example: SUPER_ADMIN_IPS=203.0.113.10,203.0.113.11
SUPER_ADMIN_IPS=

# Secret used to sign public QR repair-tracking tokens.
# Empty in production = repair-tracking endpoints return 503 (fail-closed).
# Minimum 32 chars recommended.
# Generate: openssl rand -hex 24
REPAIR_TRACKING_SECRET=


# ── STRONGLY RECOMMENDED for production ───────────────────────────────────────

# Comma-separated list of allowed browser origins (CORS).
# Required if mobile app or any external/separate-origin client calls the API.
# If the SPA is served by Express on the same origin, same-origin still works,
# but set this explicitly to lock down cross-origin requests.
# Example: ALLOWED_ORIGINS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN
ALLOWED_ORIGINS=


# ── OPTIONAL — app runs without these (graceful fallback) ────────────────────

# Redis connection. Enables distributed cache, rate-limiting, brute-force store.
# Empty = in-memory fallback (fine for a single instance). Required for scaling.
# Example: REDIS_URL=redis://localhost:6379
REDIS_URL=

# Telegram alerting (instant admin notifications). Both must be set together.
# Empty = Telegram alerts disabled (no error, alerts simply not sent).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend API key for outbound email (verification, notifications).
# Empty = email sending disabled (warning logged only).
RESEND_API_KEY=

# Sentry error monitoring DSN (server-side). Empty = Sentry disabled.
# Frontend Sentry uses VITE_SENTRY_DSN, injected at build time.
SENTRY_DSN=
VITE_SENTRY_DSN=


# ── SERVER / RUNTIME ─────────────────────────────────────────────────────────

# Must be "production" on the VPS to enable fail-closed security paths.
NODE_ENV=production

# Port the API listens on (Nginx reverse-proxies to this). Default 8080.
PORT=8080

LOG_LEVEL=info

# Directory for server-side backup files. Defaults to /home/runner/erp-backups.
# On a real VPS, set to a persistent, backed-up path, e.g. /root/db-backups.
BACKUP_DIR=/root/db-backups

# Override built-frontend path if needed. Defaults to ../../erp-system/dist/public
# FRONTEND_DIST=/var/www/muhkam-erp/artifacts/erp-system/dist/public


# ── OPTIONAL — super-admin maintenance ───────────────────────────────────────
# Force-reset super-admin PIN on next startup. Remove after reset.
# SUPER_ADMIN_PIN=000000
