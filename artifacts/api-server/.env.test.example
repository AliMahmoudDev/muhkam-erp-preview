# Integration test environment variables
# Copy this file to .env.test and fill in values for local development.
#
# In CI (GitHub Actions) JWT values are injected via repository secrets:
#   INTEGRATION_JWT_SECRET          → mapped to JWT_SECRET in the workflow step
#   INTEGRATION_JWT_REFRESH_SECRET  → mapped to JWT_REFRESH_SECRET in the workflow step
#
# If JWT_SECRET or JWT_REFRESH_SECRET are absent (e.g. on a fork without
# access to repository secrets), the integration setup file falls back to
# safe, well-named test values — but ONLY when NODE_ENV=test.

# Required: Postgres connection string pointing at a test database.
# The CI workflow uses a fresh postgres:16 service container with this URL:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/testdb

# Optional: override the default test JWT secrets.
# Minimum length: 32 characters.
# JWT_SECRET=your-custom-integration-test-jwt-secret
# JWT_REFRESH_SECRET=your-custom-integration-test-jwt-refresh-secret
