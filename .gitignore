# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
# coverage reports (anywhere in the monorepo)
**/coverage/
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/
attached_assets/

# Environment / secrets — local overrides must never be committed
# Files matching *.example ARE intentionally tracked (e.g. .env.test.example)
.env
.env.local
.env.test
.env.*.local
.deploy-keys/

# Database backup files — generated at runtime, must NEVER be committed.
# Contains tenant data. Use a secure off-site backup store (e.g. S3/R2) instead.
db-backups/
erp-backups/
*.sql.gz
*.sql.gz.enc

# Generated export / archive artifacts
ui-export.tar.gz
*.tar.gz
.vercel
